# Maudslay environment — copy to .env for local use. .env is gitignored.
#
# The CI gate and all stub-replay trials are KEY-FREE: they never read any of
# these. You only need values here for (a) a live model run, or (b) wiring the
# live IMAP email witness against a real mailbox.

# --- Live model runs (optional) --------------------------------------------
# Required only for `npm run trials -- --model <claude-...>`. Never used by the
# stub-replay path. Get a key from the Anthropic console.
ANTHROPIC_API_KEY=

# Recommended live model. NOTE: the trials CLI selects the model with the
# `--model` flag (e.g. `--model claude-opus-4-8`); this variable is a documented
# default that CI mirrors, not something the CLI currently reads on its own.
MAUDSLAY_MODEL=claude-opus-4-8

# --- Live IMAP email witness (optional) ------------------------------------
# In CI and local demos the email witness is the offline SMTP sink — no mailbox,
# no credentials. These apply only when pointing the SAME verifier at a real
# inbox over IMAP (see groundtruth/imap-live.ts, a credential-gated interface).
#
# IMPORTANT: the bundled interface reads the password from IMAP_PASSWORD (and the
# optional IMAP_PORT / IMAP_TLS / IMAP_MAILBOX below). IMAP_PASS is provided as a
# convenience alias for the runbook; set IMAP_PASSWORD when wiring a real client.
IMAP_HOST=
IMAP_USER=
IMAP_PASS=
IMAP_PASSWORD=
# Optional; defaults shown. IMAP_TLS=false disables TLS (default is on, port 993).
IMAP_PORT=993
IMAP_TLS=true
IMAP_MAILBOX=INBOX
